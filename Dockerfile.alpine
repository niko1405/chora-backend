# Aufruf:   docker build --tag juergenzimmermann/chora:2026.4.1-alpine -f Dockerfile.alpine .
#               ggf. --no-cache
#
#           Windows:   Get-Content Dockerfile.alpine | docker run --rm --interactive hadolint/hadolint:v2.14.0-debian
#           macOS:     cat Dockerfile.alpine | docker run --rm --interactive hadolint/hadolint:v2.14.0-debian
#
#           docker debug juergenzimmermann/chora:2026.4.1-alpine
#           docker save juergenzimmermann/chora:2026.4.1-alpine > chora.tar

# https://docs.docker.com/engine/reference/builder/#syntax
# https://github.com/moby/buildkit/blob/master/frontend/dockerfile/docs/reference.md
# https://hub.docker.com/r/docker/dockerfile
# https://docs.docker.com/build/building/multi-stage
# https://testdriven.io/blog/docker-best-practices
# https://containers.gitbook.io/build-containers-the-hard-way
# https://wiki.debian.org/DebianReleases
# https://github.com/astral-sh/uv-docker-example/blob/main/multistage.Dockerfile
# https://github.com/astral-sh/uv-docker-example/blob/main/Dockerfile
# https://www.saaspegasus.com/guides/uv-deep-dive

# ARG: "build-time" Variable
# ENV: "build-time" und "runtime" Variable
ARG PYTHON_MAIN_VERSION=3.14
ARG PYTHON_VERSION=${PYTHON_MAIN_VERSION}.3
ARG UV_VERSION=0.11.10
ARG ALPINE_VERSION=3.23

# ------------------------------------------------------------------------------
# S t a g e   b u i l d e r
# ------------------------------------------------------------------------------
FROM ghcr.io/astral-sh/uv:${UV_VERSION}-python${PYTHON_MAIN_VERSION}-alpine${ALPINE_VERSION} AS builder

WORKDIR /opt/app

# Enable bytecode compilation
# Copy from the cache instead of linking since it's a mounted volume
# Kein Python-Download, falls eine "managed" Python-Version verwendet wird,
# sondern in beiden Images denselben Python-Interpreter verwenden
ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PYTHON_DOWNLOADS=0

RUN <<EOF
# https://explainshell.com/explain?cmd=set+-eux
set -eux
# apk = Alpine Package Keeper
# https://wiki.alpinelinux.org/wiki/Alpine_Package_Keeper
# https://docs.alpinelinux.org/user-handbook/0.1a/Working/apk.html
# Die "Package Index"-Dateien neu synchronisieren
apk update
# Die neuesten Versionen der bereits installierten Packages installieren
apk upgrade

# ggf. Python fuer pg
# https://dl-cdn.alpinelinux.org/alpine/v3.23/main/x86_64
# https://dl-cdn.alpinelinux.org/alpine/v3.23/community/x86_64
# https://pkgs.alpinelinux.org/package/v3.23/main/x86_64/gcc
# https://pkgs.alpinelinux.org/package/v3.23/main/x86_64/g++
# https://pkgs.alpinelinux.org/package/v3.23/main/x86_64/python3-dev
# https://pkgs.alpinelinux.org/package/v3.23/main/x86_64/musl-dev
# https://pkgs.alpinelinux.org/package/v3.23/main/x86_64/linux-headers
apk --no-cache add gcc=15.2.0-r2 g++=15.2.0-r2 python3-dev=3.12.12-r0 musl-dev=1.2.5-r21 linux-headers=6.16.12-r0
EOF

# Install the project's dependencies using the lockfile and settings
RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=bind,source=uv.lock,target=uv.lock \
    --mount=type=bind,source=pyproject.toml,target=pyproject.toml <<EOF \
    uv venv
    uv sync --frozen --no-install-project --no-default-groups --no-editable
EOF

# Then, add the rest of the project source code and install it
# Installing separately from its dependencies allows optimal layer caching
COPY LICENSE README.md pyproject.toml ./
COPY src ./src
RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=bind,source=uv.lock,target=uv.lock \
    uv sync --frozen --no-default-groups --no-editable

# ------------------------------------------------------------------------------
# S t a g e   f i n a l
# ------------------------------------------------------------------------------
FROM python:${PYTHON_VERSION}-alpine${ALPINE_VERSION} AS final

# Anzeige bei "docker inspect ..."
# https://specs.opencontainers.org/image-spec/annotations
# https://spdx.org/licenses
# MAINTAINER ist deprecated https://docs.docker.com/engine/reference/builder/#maintainer-deprecated
LABEL org.opencontainers.image.title="chora" \
    org.opencontainers.image.description="Appserver chora mit Basis-Image Alpine" \
    org.opencontainers.image.version="2026.4.1-alpine" \
    org.opencontainers.image.licenses="GPL-3.0-or-later" \
    org.opencontainers.image.authors="Juergen.Zimmermann@h-ka.de"

# "working directory" fuer die Docker-Kommandos RUN, ENTRYPOINT, CMD, COPY und ADD
WORKDIR /opt/app

# https://unix.stackexchange.com/questions/217369/clear-apt-get-list
# https://medium.com/vantageai/how-to-make-your-python-docker-images-secure-fast-small-b3a6870373a0
RUN <<EOF
set -eux
# https://wiki.alpinelinux.org/wiki/Setting_up_a_new_user
addgroup --gid 10000 app
adduser --uid 10000 --ingroup app --shell /bin/bash --no-create-home --disabled-password app
# User "app" als Owner fuer das working directory
chown -R app:app /opt/app
EOF

# User "app" statt User "root"
USER app

COPY --from=builder --chown=app:app /opt/app ./

# Place executables in the environment at the front of the path
ENV PATH="/opt/app/.venv/bin:$PATH"

EXPOSE 8000

STOPSIGNAL SIGINT

ENTRYPOINT ["python", "-m", "chora"]
