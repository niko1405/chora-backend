' Preview durch <Alt>d

@startuml use-cases

left to right direction

actor "Gast" as guest
actor "Benutzer" as user
actor "Admin" as admin
actor "Betrieb" as operations
actor "Monitoring" as monitoring

rectangle chora {
  (Login)
  (Artists lesen)
  (Artists suchen)
  (Songs lesen)
  (Songs suchen)
  (Artist anlegen)
  (Artist aendern)
  (Artist loeschen)
  (Song anlegen)
  (Song aendern)
  (Song loeschen)
  (Health pruefen)
  (Metriken abfragen)
  (Dev-Daten laden)
  (Server stoppen)
}

guest --> (Login)
user --> (Artists lesen)
user --> (Artists suchen)
user --> (Songs lesen)
user --> (Songs suchen)
user --> (Artist anlegen)
user --> (Song anlegen)
user --> (Song aendern)
user --> (Song loeschen)
admin --> (Artist aendern)
admin --> (Artist loeschen)
admin --> (Server stoppen)
operations --> (Health pruefen)
operations --> (Dev-Daten laden)
monitoring --> (Metriken abfragen)

footer Chora

@enduml
